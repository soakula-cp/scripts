{
    "app_config": {
        "audio_config": {
            "audio": "pipewire"
        },
        "bluetooth_config": {
            "enabled": true
        },
        "firewall_config": {
            "firewall": "firewalld"
        },
        "fonts_config": {
            "fonts": [
                "noto-fonts",
                "noto-fonts-emoji"
            ]
        },
        "print_service_config": {
            "enabled": true
        }
    },
    "archinstall-language": "English",
    "auth_config": {},
    "bootloader_config": {
        "bootloader": "Grub",
        "removable": false,
        "uki": false
    },
    "custom_commands": [
        "mkdir -p /mnt/home/sonapraneeth/Softwares",
        "pushd /mnt/home/sonapraneeth/Softwares && git clone https://github.com/soakula-cp/scripts.git && pushd scripts/archinstall && chmod +x install.sh && bash ./install.sh > /mnt/home/sonapraneeth/Softwares/install.log"
    ],
    "hostname": "vmware",
    "kernels": [
        "linux-lts"
    ],
    "locale_config": {
        "kb_layout": "us",
        "sys_enc": "UTF-8",
        "sys_lang": "en_US.UTF-8"
    },
    "mirror_config": {
        "custom_repositories": [],
        "custom_servers": [],
        "mirror_regions": {
            "India": [
                "http://in.mirrors.cicku.me/archlinux/$repo/os/$arch",
                "https://in.mirrors.cicku.me/archlinux/$repo/os/$arch",
                "https://mirror.albony.in/archlinux/$repo/os/$arch",
                "https://mirror.del2.albony.in/archlinux/$repo/os/$arch",
                "https://mirror.maa.albony.in/archlinux/$repo/os/$arch",
                "http://in-mirror.garudalinux.org/archlinux/$repo/os/$arch",
                "http://mirror.sahil.world/archlinux/$repo/os/$arch",
                "https://mirror.sahil.world/archlinux/$repo/os/$arch",
                "http://mirrors.nxtgen.com/archlinux-mirror/$repo/os/$arch",
                "https://mirrors.nxtgen.com/archlinux-mirror/$repo/os/$arch",
                "https://mirrors.abhy.me/archlinux/$repo/os/$arch",
                "http://mirror.4v1.in/archlinux/$repo/os/$arch",
                "https://mirror.4v1.in/archlinux/$repo/os/$arch",
                "https://in.arch.niranjan.co/$repo/os/$arch",
                "https://archlinux.kushwanthreddy.com/$repo/os/$arch",
                "https://mirror.dawn.org.in/arch/$repo/os/$arch"
            ]
        },
        "optional_repositories": [
            "multilib"
        ]
    },
    "network_config": {
